rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isVerified() && request.auth.token.email == 'cclackerz@gmail.com'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Gear Item
    function isValidGearItem(data) {
      return data.keys().hasAll(['group', 'guid', 'displayName', 'updatedAt', 'updatedBy'])
        && data.group is string && data.group.size() <= 64
        && data.guid is string && data.guid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 256
        && data.updatedAt == request.time
        && data.updatedBy == request.auth.uid;
    }

    // Validation Blueprint for Verified Mapping
    function isValidMapping(data) {
      return data.keys().hasAll(['guid', 'aliases', 'updatedAt', 'updatedBy'])
        && data.guid is string && data.guid.size() <= 128
        && data.aliases is list && data.aliases.size() <= 200
        && data.updatedAt == request.time
        && data.updatedBy == request.auth.uid;
    }

    // Validation Blueprint for Parameter Mapping
    function isValidParameterMapping(data) {
      return data.keys().hasAll(['gearName', 'parameter', 'conversion', 'exportParameterName', 'updatedAt', 'updatedBy'])
        && data.gearName is string && data.gearName.size() <= 128
        && data.parameter is string && data.parameter.size() <= 128
        && data.conversion is string && data.conversion.size() <= 64
        && data.exportParameterName is string && data.exportParameterName.size() <= 128
        && data.updatedAt == request.time
        && data.updatedBy == request.auth.uid;
    }

    // Validation Blueprint for Mic Placement Mapping
    function isValidMicPlacementMapping(data) {
      return data.keys().hasAll(['gear', 'friendly_setting', 'friendly_value', 'maps_to', 'updatedAt', 'updatedBy'])
        && data.gear is string && data.gear.size() <= 256
        && data.friendly_setting is string && data.friendly_setting.size() <= 128
        && data.friendly_value is string && data.friendly_value.size() <= 128
        && data.maps_to is map
        && data.updatedAt == request.time
        && data.updatedBy == request.auth.uid;
    }

    // --- Main Collections ---

    match /catalogue/{guid} {
      allow read: if true; // Catalogue is public for the brain
      allow delete: if isVerified();
      allow create, update: if (isVerified() && isValidId(guid) && isValidGearItem(incoming())) && (
        isAdmin() ||
        request.method == 'create' || (
          // Allow updates to any valid field, including removing old snake_case fields
          incoming().diff(existing()).affectedKeys().hasOnly([
            'displayName', 'otherNames', 'knobs', 'updatedAt', 'updatedBy', 
            'slot', 'paramSuffix', 'usedInPresets', 'examplePresets', 'group', 'guid',
            'display_name', 'other_observed_names', 'used_in_presets', 'param_suffix' // Legacy fields
          ])
          && incoming().guid == existing().guid
        )
      );
    }

    match /verified_cabs/{guid} {
      allow read: if true;
      allow delete: if isVerified();
      allow create, update: if isVerified() && isValidId(guid) && isValidMapping(incoming()) && (
        isAdmin() ||
        request.method == 'create' || (
          incoming().diff(existing()).affectedKeys().hasOnly(['aliases', 'updatedAt', 'updatedBy', 'guid'])
          && incoming().guid == existing().guid
        )
      );
    }

    match /verified_speakers/{guid} {
      allow read: if true;
      allow delete: if isVerified();
      allow create, update: if isVerified() && isValidId(guid) && isValidMapping(incoming()) && (
        isAdmin() ||
        request.method == 'create' || (
          incoming().diff(existing()).affectedKeys().hasOnly(['aliases', 'updatedAt', 'updatedBy', 'guid'])
          && incoming().guid == existing().guid
        )
      );
    }

    match /verified_mics/{guid} {
      allow read: if true;
      allow delete: if isVerified();
      allow create, update: if isVerified() && isValidId(guid) && isValidMapping(incoming()) && (
        isAdmin() ||
        request.method == 'create' || (
          incoming().diff(existing()).affectedKeys().hasOnly(['aliases', 'updatedAt', 'updatedBy', 'guid'])
          && incoming().guid == existing().guid
        )
      );
    }

    match /parameter_mappings/{mappingId} {
      allow read: if true;
      allow delete: if isVerified();
      allow create, update: if isVerified() && isValidId(mappingId) && isValidParameterMapping(incoming()) && (
        isAdmin() ||
        request.method == 'create' || (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'gearName', 'parameter', 'visualMin', 'visualMax', 'visualUnit',
            'exportMin', 'exportMax', 'exportParameterName', 'conversion', 'formula',
            'updatedAt', 'updatedBy', 'id'
          ])
          && incoming().id == existing().id
        )
      );
    }

    match /mic_placement_mappings/{mappingId} {
      allow read: if true;
      allow delete: if isVerified();
      allow create, update: if isVerified() && isValidId(mappingId) && isValidMicPlacementMapping(incoming()) && (
        isAdmin() ||
        request.method == 'create' || (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'gear', 'friendly_setting', 'friendly_value', 'maps_to', 'target', 
            'friendly_name', 'xml_values', 'status', 'validation_status', 'source', 
            'updatedAt', 'updatedBy', 'id'
          ])
          && incoming().id == existing().id
        )
      );
    }

    // System collection for connection test
    match /system/connection_test {
      allow read: if true;
    }
  }
}
