{
  "entities": {
    "gear_item": {
      "title": "AT5 Gear Item",
      "description": "A piece of gear in the AmpliTude 5 catalog",
      "type": "object",
      "properties": {
        "group": { "type": "string" },
        "guid": { "type": "string" },
        "slot": { "type": "string" },
        "displayName": { "type": "string" },
        "otherNames": { "type": "array", "items": { "type": "string" } },
        "usedInPresets": { "type": "integer" },
        "paramSuffix": { "type": "string" },
        "knobs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "default": { "type": "any" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["group", "guid", "displayName"]
    },
    "verified_mapping": {
      "title": "Verified Protocol Mapping",
      "description": "A mapping between a GUID and its known aliases for Cabs, Speakers, or Mics",
      "type": "object",
      "properties": {
        "guid": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["guid", "aliases"]
    },
    "parameter_mapping": {
      "title": "Gear Parameter Mapping",
      "description": "Definition of visual to export conversion rules for a gear's parameter",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gearName": { "type": "string" },
        "parameter": { "type": "string" },
        "visualMin": { "type": "number" },
        "visualMax": { "type": "number" },
        "visualUnit": { "type": "string" },
        "exportMin": { "type": "number" },
        "exportMax": { "type": "number" },
        "exportParameterName": { "type": "string" },
        "conversion": { "type": "string" },
        "formula": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["gearName", "parameter", "conversion", "exportParameterName"]
    },
    "mic_placement_mapping": {
      "title": "Mic Placement Mapping",
      "description": "Custom mic placement to XML value mappings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gear": { "type": "string" },
        "friendly_setting": { "type": "string" },
        "target": { "type": "string" },
        "friendly_value": { "type": "string" },
        "friendly_name": { "type": "string" },
        "maps_to": { "type": "object" },
        "xml_values": { "type": "object" },
        "status": { "type": "string" },
        "validation_status": { "type": "string" },
        "source": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["gear", "friendly_setting", "friendly_value", "maps_to"]
    }
  },
  "firestore": {
    "/catalogue/{guid}": {
      "schema": "gear_item",
      "description": "Main gear catalogue"
    },
    "/verified_cabs/{guid}": {
      "schema": "verified_mapping",
      "description": "Verified Cabinet GUID mappings"
    },
    "/verified_speakers/{guid}": {
      "schema": "verified_mapping",
      "description": "Verified Speaker GUID mappings"
    },
    "/verified_mics/{guid}": {
      "schema": "verified_mapping",
      "description": "Verified Microphone GUID mappings"
    },
    "/parameter_mappings/{mappingId}": {
      "schema": "parameter_mapping",
      "description": "A mapping for a gear parameter conversion rule"
    },
    "/mic_placement_mappings/{mappingId}": {
      "schema": "mic_placement_mapping",
      "description": "Custom mic placement mappings to XML attributes"
    }
  }
}
